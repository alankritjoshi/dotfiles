{
  "lastChangelogVersion": "0.65.0",
  "packages": [
{{ if eq .machine "vanik" }}    "https://github.com/shopify-playground/shop-pi-fy",
    "https://github.com/davebcn87/pi-autoresearch",
    "git:github.com/shopify-playground/pi-tool-gateway-extension"
{{ else }}    "https://github.com/davebcn87/pi-autoresearch"
{{ end }}  ],
  "defaultThinkingLevel": "xhigh",
  "theme": "catppuccin-mocha",
  "defaultProvider": "anthropic",
  "defaultModel": "claude-opus-4-6",
  "enabledModels": [
    "anthropic/claude-opus-4-6",
    "anthropic-250k*/claude-opus-4-6"
  ],
  "markdown": {
    "codeBlockIndent": ""
  },
  "compaction": {
    "enabled": true,
    "reserveTokens": 32768,
    "keepRecentTokens": 50000
  },
  "hideThinkingBlock": true,
  "npmCommand": [
    "pnpm"
  ]
}
